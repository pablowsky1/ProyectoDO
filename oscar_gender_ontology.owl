<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:dct="http://purl.org/dc/terms/"
   xmlns:owl="http://www.w3.org/2002/07/owl#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
   xmlns:vann="http://purl.org/vocab/vann/"
>
  <rdf:Description rdf:about="http://example.org/oscar#Director">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/oscar#Person"/>
    <rdfs:label xml:lang="en">Director</rdfs:label>
    <rdfs:comment xml:lang="en">A person who controls a movie's artistic and dramatic aspects.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://example.org/oscar#Director"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/oscar#ceremonyYear">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/oscar#Ceremony"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYear"/>
    <rdfs:label xml:lang="en">ceremonyYear</rdfs:label>
    <rdfs:comment xml:lang="en">The year in which the Oscar ceremony took place.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://example.org/oscar#ceremonyYear"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/oscar#Producer">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/oscar#Person"/>
    <rdfs:label xml:lang="en">Producer</rdfs:label>
    <rdfs:comment xml:lang="en">A person responsible for the financial and organizational aspects of a movie.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://example.org/oscar#Producer"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/oscar#Gender">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:oneOf rdf:nodeID="nf417b8c8e28541ad847913ade3e83a06b1"/>
    <rdfs:label xml:lang="en">Gender</rdfs:label>
    <rdfs:comment xml:lang="en">The gender classification of a person used for industry analysis.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://example.org/oscar#Gender"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/oscar#personName">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/oscar#Person"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label xml:lang="en">personName</rdfs:label>
    <rdfs:comment xml:lang="en">The full name of the person.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://example.org/oscar#personName"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/oscar#Genre">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:resource="https://schema.org/Genre"/>
    <rdfs:label xml:lang="en">Genre</rdfs:label>
    <rdfs:comment xml:lang="en">A category of artistic composition, as in movies, characterized by similarities in form, style, or subject matter.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://example.org/oscar#Genre"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf417b8c8e28541ad847913ade3e83a06b5">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://example.org/oscar#movieTitle"/>
    <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/oscar#nominationCategory">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://example.org/oscar#Nomination"/>
    <rdfs:range rdf:resource="http://example.org/oscar#Category"/>
    <rdfs:label xml:lang="en">nominationCategory</rdfs:label>
    <rdfs:comment xml:lang="en">Links a Nomination event to the specific Category of the award.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://example.org/oscar#nominationCategory"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/oscar#movieTitle">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/oscar#Movie"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label xml:lang="en">movieTitle</rdfs:label>
    <rdfs:comment xml:lang="en">The official title of the movie.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://example.org/oscar#movieTitle"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/oscar#Award">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Award</rdfs:label>
    <rdfs:comment xml:lang="en">The institution or organization giving the prize (e.g., Academy of Motion Picture Arts and Sciences).</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://example.org/oscar#Award"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/oscar#releaseYear">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/oscar#Movie"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYear"/>
    <rdfs:label xml:lang="en">releaseYear</rdfs:label>
    <rdfs:comment xml:lang="en">The year the movie was released to the public.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://example.org/oscar#releaseYear"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/oscar#won">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/oscar#Nomination"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <rdfs:label xml:lang="en">won</rdfs:label>
    <rdfs:comment xml:lang="en">Boolean value indicating if the nomination resulted in a win (True) or not (False).</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://example.org/oscar#won"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/oscar#directed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://example.org/oscar#Director"/>
    <rdfs:range rdf:resource="http://example.org/oscar#Movie"/>
    <rdfs:label xml:lang="en">directed</rdfs:label>
    <rdfs:comment xml:lang="en">Links a Director to the Movie they have directed.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://example.org/oscar#directed"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/oscar#">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <dct:creator>Oscar Gender Analysis Group</dct:creator>
    <dct:title xml:lang="en">Extended Oscar Gender Analysis Ontology</dct:title>
    <dct:description xml:lang="en">Ontology for modelling movies, people, and their participation in the Academy Awards (Oscars) with a focus on gender analysis.</dct:description>
    <dct:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-03-20</dct:created>
    <vann:preferredNamespacePrefix>oscar</vann:preferredNamespacePrefix>
    <vann:preferredNamespaceUri>http://example.org/oscar#</vann:preferredNamespaceUri>
    <owl:versionInfo>2.1</owl:versionInfo>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/oscar#hasNomination">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://example.org/oscar#Movie"/>
    <rdfs:range rdf:resource="http://example.org/oscar#Nomination"/>
    <rdfs:label xml:lang="en">hasNomination</rdfs:label>
    <rdfs:comment xml:lang="en">Links a Movie to a specific Award Nomination event.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://example.org/oscar#hasNomination"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf417b8c8e28541ad847913ade3e83a06b3">
    <rdf:first rdf:resource="http://example.org/oscar#Undetermined"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf417b8c8e28541ad847913ade3e83a06b2">
    <rdf:first rdf:resource="http://example.org/oscar#Male"/>
    <rdf:rest rdf:nodeID="nf417b8c8e28541ad847913ade3e83a06b3"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/oscar#hasGenre">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://example.org/oscar#Movie"/>
    <rdfs:range rdf:resource="http://example.org/oscar#Genre"/>
    <rdfs:label xml:lang="en">hasGenre</rdfs:label>
    <rdfs:comment xml:lang="en">Associates a Movie with a specific film Genre (e.g., Drama, Comedy).</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://example.org/oscar#hasGenre"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/oscar#Ceremony">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Ceremony</rdfs:label>
    <rdfs:comment xml:lang="en">The annual event where Oscar awards are announced and presented.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://example.org/oscar#Ceremony"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/oscar#femaleCastPercentage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/oscar#Movie"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    <rdfs:label xml:lang="en">femaleCastPercentage</rdfs:label>
    <rdfs:comment xml:lang="en">A calculated percentage of female members in the movie's cast.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://example.org/oscar#femaleCastPercentage"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/oscar#imdbId">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/oscar#Movie"/>
    <rdfs:domain rdf:resource="http://example.org/oscar#Person"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label xml:lang="en">imdbId</rdfs:label>
    <rdfs:comment xml:lang="en">The unique identifier assigned by IMDb for movies and people.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://example.org/oscar#imdbId"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/oscar#ceremonyOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://example.org/oscar#Ceremony"/>
    <rdfs:range rdf:resource="http://example.org/oscar#Award"/>
    <rdfs:label xml:lang="en">ceremonyOf</rdfs:label>
    <rdfs:comment xml:lang="en">Links a Ceremony to the overarching Award organization (e.g., The Oscars).</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://example.org/oscar#ceremonyOf"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/oscar#Category">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Category</rdfs:label>
    <rdfs:comment xml:lang="en">The specific division of an award (e.g., Best Actress, Best Cinematography).</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://example.org/oscar#Category"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/dc/terms/created">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/oscar#categoryName">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/oscar#Category"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label xml:lang="en">categoryName</rdfs:label>
    <rdfs:comment xml:lang="en">The name of the award category (e.g., 'Best Picture').</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://example.org/oscar#categoryName"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/oscar#actedIn">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://example.org/oscar#Actor"/>
    <rdfs:range rdf:resource="http://example.org/oscar#Movie"/>
    <rdfs:label xml:lang="en">actedIn</rdfs:label>
    <rdfs:comment xml:lang="en">Links an Actor to a Movie they performed in.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://example.org/oscar#actedIn"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/oscar#atCeremony">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://example.org/oscar#Nomination"/>
    <rdfs:range rdf:resource="http://example.org/oscar#Ceremony"/>
    <rdfs:label xml:lang="en">atCeremony</rdfs:label>
    <rdfs:comment xml:lang="en">Indicates the specific Award Ceremony where the nomination occurred.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://example.org/oscar#atCeremony"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/oscar#Person">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:resource="https://schema.org/Person"/>
    <rdfs:label xml:lang="en">Person</rdfs:label>
    <rdfs:comment xml:lang="en">An individual involved in the film industry as an actor, director, or producer.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://example.org/oscar#Person"/>
    <rdfs:subClassOf rdf:nodeID="nf417b8c8e28541ad847913ade3e83a06b4"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/oscar#Movie">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:resource="https://schema.org/Movie"/>
    <rdfs:label xml:lang="en">Movie</rdfs:label>
    <rdfs:comment xml:lang="en">A cinematographic work (film) that can be nominated for awards.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://example.org/oscar#Movie"/>
    <rdfs:subClassOf rdf:nodeID="nf417b8c8e28541ad847913ade3e83a06b5"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/oscar#nominee">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://example.org/oscar#Nomination"/>
    <rdfs:range rdf:resource="http://example.org/oscar#Person"/>
    <rdfs:label xml:lang="en">nominee</rdfs:label>
    <rdfs:comment xml:lang="en">Links a Nomination event to the specific Person being nominated.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://example.org/oscar#nominee"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf417b8c8e28541ad847913ade3e83a06b4">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://example.org/oscar#hasGender"/>
    <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
    <owl:onClass rdf:resource="http://example.org/oscar#Gender"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/vocab/vann/preferredNamespaceUri">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/oscar#Actor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://example.org/oscar#Person"/>
    <rdfs:label xml:lang="en">Actor</rdfs:label>
    <rdfs:comment xml:lang="en">A person who portrays a character in a movie.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://example.org/oscar#Actor"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/dc/terms/description">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/oscar#hasGender">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://example.org/oscar#Person"/>
    <rdfs:range rdf:resource="http://example.org/oscar#Gender"/>
    <rdfs:label xml:lang="en">hasGender</rdfs:label>
    <rdfs:comment xml:lang="en">Links a Person to their gender identity for statistical analysis.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://example.org/oscar#hasGender"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/dc/terms/creator">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/oscar#produced">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://example.org/oscar#Producer"/>
    <rdfs:range rdf:resource="http://example.org/oscar#Movie"/>
    <rdfs:label xml:lang="en">produced</rdfs:label>
    <rdfs:comment xml:lang="en">Links a Producer to the Movie they have produced.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://example.org/oscar#produced"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/oscar#budget">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://example.org/oscar#Movie"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <rdfs:label xml:lang="en">budget</rdfs:label>
    <rdfs:comment xml:lang="en">The production budget of the movie in USD.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://example.org/oscar#budget"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/oscar#Nomination">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Nomination</rdfs:label>
    <rdfs:comment xml:lang="en">The formal act of being proposed for an Oscar award.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://example.org/oscar#Nomination"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf417b8c8e28541ad847913ade3e83a06b1">
    <rdf:first rdf:resource="http://example.org/oscar#Female"/>
    <rdf:rest rdf:nodeID="nf417b8c8e28541ad847913ade3e83a06b2"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/vocab/vann/preferredNamespacePrefix">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/oscar#Undetermined">
    <rdf:type rdf:resource="http://example.org/oscar#Gender"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/dc/terms/title">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/oscar#Male">
    <rdf:type rdf:resource="http://example.org/oscar#Gender"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/dc/terms/license">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/oscar#Female">
    <rdf:type rdf:resource="http://example.org/oscar#Gender"/>
  </rdf:Description>
</rdf:RDF>
